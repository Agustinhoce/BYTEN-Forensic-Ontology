      "sameAs": ["https://byten.com.br/glossario-forense#paradoxo-temporal", "https://byten.com.br/blog/analise-forense-pix-boletos-fraudes"],
      "inDefinedTermSet": "https://byten.com.br/ontology/risk-taxonomy",
      "skos:inScheme": { "@id": "https://byten.com.br/ontology/risk-taxonomy" },
      "skos:topConceptOf": { "@id": "https://byten.com.br/ontology/risk-taxonomy" },
      "termCode": "BYTEN:TP-001",
      "name": "Paradoxo Temporal",
      "description": "Inconsistência cronológica verificável entre metadados de sistema/arquivo e registros de liquidação externa (ex: SPI/BACEN).",
      "byten:computable_spec": {
        "inputs": ["external_log_timestamp", "file_creation_timestamp", "system_timestamp"],
        "rules": [
          {
            "id": "r1",
            "expr": "normalize_utc(file_creation_timestamp) < normalize_utc(external_log_timestamp)",
            "type": "hard_violation",
            "outcome": "byten:red-risk"
          }
        ],
        "threshold_ms": 5000
      },
